{
  "name": "personal-portfolio",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "prebuild": "npm run verify:assets",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "pretest": "npm run verify:assets",
    "test": "npm run test:guards && ng test",
    "test:guards": "node --test scripts/validate-portfolio-data.test.mjs scripts/generate-images.test.mjs",
    "validate:content": "node scripts/validate-portfolio-data.mjs",
    "images:generate": "node scripts/generate-images.mjs",
    "images:check": "node scripts/generate-images.mjs --check",
    "verify:assets": "npm run validate:content && npm run images:check",
    "lint": "ng lint"
  },
  "private": true,
  "packageManager": "npm@11.12.0",
  "dependencies": {
    "@angular/common": "21.2.18",
    "@angular/compiler": "21.2.18",
    "@angular/core": "21.2.18",
    "@angular/forms": "21.2.18",
    "@angular/platform-browser": "21.2.18",
    "@angular/platform-server": "21.2.18",
    "@angular/router": "21.2.18",
    "@angular/ssr": "21.2.19",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "21.2.19",
    "@angular/cli": "21.2.19",
    "@angular/compiler-cli": "21.2.18",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "angular-eslint": "21.3.1",
    "eslint": "^10.0.3",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "sharp": "0.35.3",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.0.8"
  }
}
